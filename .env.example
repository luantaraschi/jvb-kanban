# Copie este arquivo para .env e preencha os valores
# NUNCA suba o arquivo .env para o GitHub

# Conexao do Postgres/Supabase (use a string do pooler)
DATABASE_URL=postgresql://postgres.xxxxx:[senha]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Segredo para assinar os tokens JWT
JWT_SECRET=troque_por_uma_string_longa_e_aleatoria_aqui_minimo_32_caracteres

# Primeiro gestor criado no bootstrap automatico
ADMIN_NAME=Gestor
ADMIN_USERNAME=gestor
ADMIN_PASSWORD=troque_por_uma_senha_forte

# IA do painel do gestor
AI_ENABLED=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
AI_TIMEOUT_MS=45000

# Porta local
PORT=3000

# Ambiente
NODE_ENV=development
